  "knowledge_core": {
    "center_pins": [
      {
        "element_id": "BRAIN_CENTERPIN_001",
        "type": "FACT",
        "content": "Brainビジネスにおいて成果を上げるためのセンターピン（最重要マインド）は、「完了主義（完璧主義の排除）」「量産思考」「仕組み化思考」の3つである。",
        "base_purity_score": 90.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_002",
        "type": "LOGIC",
        "content": "Brainのコンテンツ作成において、30%の労力で作ったものと100%の労力で作ったものとで質に大きな差は生まれないため、100%を目指して過剰な時間を費やすことは無駄である。",
        "base_purity_score": 85.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_003",
        "type": "SOP",
        "content": "コンテンツ作成時は完璧主義を捨て、30%の完成度であってもまずは出品して世に出す「完了主義」を徹底すること。",
        "base_purity_score": 95.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_004",
        "type": "SOP",
        "content": "まずはBrainで最初の売上（例：1万円）を作る「0→1」を達成し、その手法の再現性を高めるための分析と改善を行うこと。",
        "base_purity_score": 90.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_005",
        "type": "LOGIC",
        "content": "再現性を高めた「1万円稼ぐ手法」を100回積み上げることで、単純計算で100万円の売上を達成することができる。",
        "base_purity_score": 95.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_006",
        "type": "LOGIC",
        "content": "個人の作業時間と労力には限界があるため、自分1人の力だけでコンテンツを量産し100回積み上げようとすることは事実上不可能である。",
        "base_purity_score": 85.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_007",
        "type": "SOP",
        "content": "再現性のあるノウハウをマニュアル化し、クラウドソーシング等の外注を活用して作業を委託することで、量産のための仕組みを構築すること。",
        "base_purity_score": 100.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_008",
        "type": "FACT",
        "content": "クラウドソーシングを活用すれば、動画の文字起こしやリライトなどの単純作業を1分あたり約30円（30分動画で約900円）という非常に安価なコストで外注できる。",
        "base_purity_score": 100.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_009",
        "type": "LOGIC",
        "content": "インフルエンサービジネスなど、自分がいないと回らない属人的なビジネスはスケールできないため、天性の才能がない凡人が大きく稼ぐことには適していない。",
        "base_purity_score": 85.0
      },
      {
        "element_id": "BRAIN_CENTERPIN_010",
        "type": "FACT",
        "content": "属人性を排除したBrainのコンテンツビジネスは、マニュアル化と外注化を組み合わせることで、自分が稼働しなくても利益を生むフル外注の仕組みを構築可能である。",
        "base_purity_score": 95.0
      }
    ],
